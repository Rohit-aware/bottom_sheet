{
  "name": "@rn-lab/bottom-sheet",
  "version": "1.0.0",
  "description": "A production-ready, framework-agnostic bottom sheet component for React Native with snap points, imperative API, and render props.",
  "main": "lib/module/index.js",
  "module": "lib/module/index.js",
  "react-native": "src/index.ts",
  "types": "lib/typescript/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "react-native": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "README.md"
  ],
  "scripts": {
    "build": "bob build",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf lib",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "react-native",
    "bottom-sheet",
    "modal",
    "gesture",
    "reanimated",
    "snap-points"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-gesture-handler": ">=2.18.0",
    "react-native-reanimated": ">=3.16.0",
    "react-native-safe-area-context": ">=5.0.0",
    "react-native-worklets": ">=1.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "jest": "^29.0.0",
    "react-native-builder-bob": "^0.40.0",
    "typescript": "^5.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "author": "Rohit Aware",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rohit-aware/design-system.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
